# mlb-analytics environment — copy to .env and fill in. NEVER commit .env.
#
# Phase 6 portability: every stage reads its config from env vars ONLY.
# No stage may hardcode an absolute local path.

# --- Seasons (regular + postseason). Current season pulled incrementally. ---
MLB_SEASONS=2023,2024,2025

# --- Warehouse + data roots (S3 URIs in AWS mode; local paths here) ---
MLB_DUCKDB_PATH=data/warehouse.duckdb
MLB_BRONZE_DIR=data/bronze
MLB_GOLD_DIR=data/gold
MLB_RESULTS_DIR=data/results

# --- Politeness: descriptive User-Agent for every outbound API/scrape call ---
MLB_USER_AGENT=mlb-analytics/0.1 (portfolio; contact stevemarn27@gmail.com)

# --- Betting lines. Source decided at Phase 0 DECISION POINT; key only if used. ---
# The Odds API free tier: https://the-odds-api.com  (~500 credits/month)
ODDS_API_KEY=
